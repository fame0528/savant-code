{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@savant-code/common/*": ["./common/src/*"],
      "@savant-code/evals/*": ["./evals/*"],
      "@savant-code/sdk": ["./sdk/src/index.ts"],
      "@savant-code/sdk/*": ["./sdk/*"],
      "@savant-code/agent-runtime/*": ["./packages/agent-runtime/src/*"],
