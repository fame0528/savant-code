# Savant-Code CLI — required environment variables
#
# Copy this file to .env and fill in real values. NEVER commit .env.
# All env vars are validated by `common/src/env-schema.ts` on CLI startup.
# Optional vars (marked OPTIONAL) may be left unset.

# Environment: dev | test | prod
NEXT_PUBLIC_SC_ENVIRONMENT=dev

# Public app URL (the savant-code.dev / savant-free.com web app)
NEXT_PUBLIC_SAVANT_CODE_APP_URL=https://savant-code.dev
# OPTIONAL: separate Savant-Free web app URL
# NEXT_PUBLIC_SAVANT_FREE_APP_URL=https://savant-free.com

# Support email shown in CLI help and error messages
NEXT_PUBLIC_SUPPORT_EMAIL=support@savant-code.dev

# PostHog analytics (your PostHog project key + host)
NEXT_PUBLIC_POSTHOG_API_KEY=phc_replace_me_with_real_key
NEXT_PUBLIC_POSTHOG_HOST_URL=https://us.i.posthog.com
# OPTIONAL: PostHog / Gravity pixel ID (if you have one)
# NEXT_PUBLIC_GRAVITY_PIXEL_ID=

# Stripe (publishable key + customer portal URL)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL=https://billing.stripe.com/p/login/test_replace_me

# OPTIONAL: Google site verification ID (for SEO, web only — CLI ignores)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_ID=

# Web port the local CLI tries to bind to when opening the auth flow
NEXT_PUBLIC_WEB_PORT=3000

# --- Additional env vars the CLI will need at runtime (NOT validated by env-schema.ts) ---

# LLM provider keys. Pick whichever provider(s) you'll use.
ANTHROPIC_API_KEY=sk-ant-replace-me
# OPENAI_API_KEY=sk-replace-me
# GOOGLE_GEMINI_API_KEY=replace-me

# OPTIONAL: Override default model selection
# SAVANT_CODE_DEFAULT_MODEL=anthropic/claude-sonnet-4.6
