# Savant-Code CLI — environment variables
#
# Copy this file to .env and fill in real values. NEVER commit .env.
# All 11 NEXT_PUBLIC_* vars are validated by `common/src/env-schema.ts` on startup
# and will crash the CLI if missing. Everything else is loaded lazily — only the
# features you use will need their keys.
#
# ───────────────────────────────────────────────────────────────────────────────
# MODEL PROVIDERS (LLMs)
# ───────────────────────────────────────────────────────────────────────────────
#
# The codebase supports these model providers (see common/src/constants/model-config.ts):
#   • anthropic    — Claude 4.5, 4.6, 3.5, etc. (direct)
#   • openai       — GPT-4o, o3, o4-mini, etc. (direct)
#   • openrouter/  — Claude/GPT/Gemini/Grok via OpenRouter (GATEWAY ROUTED VIA SAVANT-CODE BACKEND)
#   • google/      — Gemini 2.5 Pro/Flash (direct OR via Savant-Code backend)
#   • x-ai/        — Grok 4 (direct OR via Savant-Code backend)
#   • deepseek/    — DeepSeek V4 Pro/Flash (direct OR via Savant-Code backend)
#   • mimo/        — Xiaomi MiMo 2.5 (via Savant-Code backend)
#   • minimax/     — MiniMax M3 (via Savant-Code backend)
#   • moonshotai/  — Kimi K2.6, K2.7-Code (via Savant-Code backend)
#   • opencode/    — OpenCode Zen models (OPENCODE_API_KEY direct)
#   • (Savant-Code backend) — proxy for most providers
#
# ── "MASTER KEY" BEHAVIOR ─────────────────────────────────────────────────────
# `SAVANT_CODE_API_KEY` is effectively a master key: it routes you to the
# Savant-Code backend, which proxies Anthropic / OpenAI / OpenRouter / Gemini /
# DeepSeek / Grok / Moonshot / MiMo / MiniMax / OpenCode without needing direct
# provider keys. Pick ONE approach:
#
#   A) Set ONLY SAVANT_CODE_API_KEY → most providers work, billed through Savant-Code
#   B) Set direct provider keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.) → bypass
#      the Savant-Code backend, billed by the provider
#
# There is no separate OPENROUTER_API_KEY — OpenRouter access is via (A).

# ── Master key: Savant-Code backend (RECOMMENDED) ────────────────────────────
# Routes through the Savant-Code backend. Get a key at https://savant-code.dev/settings/api
SAVANT_CODE_API_KEY=sk-savant-code-replace-me

# ── OpenRouter API key (BYOK — Bring Your Own Key) ──────────────────────────
# If set, the Savant-Code backend forwards your OpenRouter key upstream
# (via the `x-openrouter-api-key` header) and bills OpenRouter calls to
# YOUR account. Without this, OpenRouter calls go through the backend's
# pool (billed to your Savant-Code account).
# This is the right knob for "OpenRouter is my primary provider".
# Get a key at https://openrouter.ai/keys
#
# Note: Savant-Code is a CONSUMER of LLM APIs, not a provider. Real model
# providers are openrouter / anthropic / openai / google / x-ai / deepseek
# / mimo / minimax / moonshotai / opencode. Savant-Code just routes to them.
OPENROUTER_API_KEY=sk-or-v1-replace-me

# DEPRECATED alias for OPENROUTER_API_KEY. Kept for backward compat — will
# be honored if OPENROUTER_API_KEY is not set. Prefer OPENROUTER_API_KEY.
# SAVANT_CODE_BYOK_OPENROUTER=sk-or-v1-replace-me

# ── Direct provider keys (OPTIONAL — only if bypassing the Savant-Code backend) ─
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-replace-me
# GOOGLE_API_KEY=replace-me                        # Used for Gemini (some code paths)
# GOOGLE_GEMINI_API_KEY=replace-me                 # Alt name (some code paths)
# XAI_API_KEY=xai-replace-me                       # Grok
# DEEPSEEK_API_KEY=replace-me                      # DeepSeek direct
# OPENCODE_API_KEY=replace-me                      # OpenCode Zen

# ── ChatGPT OAuth (OPTIONAL — alternative to OPENAI_API_KEY) ───────────────────
# SAVANT_CODE_CHATGPT_OAUTH_TOKEN=                  # OAuth bearer token

# ── Claude Code subscription (OPTIONAL — uses your Claude Code login) ────────
# CLAUDE_CODE_KEY=

# ───────────────────────────────────────────────────────────────────────────────
# TOOL API KEYS (OPTIONAL — only required by the tools that use them)
# ───────────────────────────────────────────────────────────────────────────────

# Web search (Serper)
SERPER_API_KEY=

# Docs search (Context7)
CONTEXT7_API_KEY=

# Email (SendGrid) — only used by the gravity-index tool
SENDGRID_API_KEY=

# ───────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* (REQUIRED — validated by env-schema.ts at startup)
# ───────────────────────────────────────────────────────────────────────────────
# The CLI loads these for analytics, billing, and the auth flow. Missing any of
# the 8 required ones below will crash the CLI immediately.

# Environment tier
NEXT_PUBLIC_SC_ENVIRONMENT=dev                 # dev | test | prod

# Public app URL (the web app the CLI's auth flow redirects to)
NEXT_PUBLIC_SAVANT_CODE_APP_URL=https://savant-code.dev
# OPTIONAL: separate Savant-Free web app URL
# NEXT_PUBLIC_SAVANT_FREE_APP_URL=https://savant-free.com

# Support email shown in /help and error messages
NEXT_PUBLIC_SUPPORT_EMAIL=support@savant-code.dev

# PostHog analytics (client-side)
NEXT_PUBLIC_POSTHOG_API_KEY=phc_replace_me
NEXT_PUBLIC_POSTHOG_HOST_URL=https://us.i.posthog.com

# Stripe (publishable key + customer portal URL)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL=https://billing.stripe.com/p/login/test_replace_me

# Local web port (CLI auth flow)
NEXT_PUBLIC_WEB_PORT=3000

# OPTIONAL: analytics pixel + Google site verification
# NEXT_PUBLIC_GRAVITY_PIXEL_ID=
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_ID=

# ───────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE POSTHOG (OPTIONAL — separate from client-side NEXT_PUBLIC_POSTHOG_*)
# ───────────────────────────────────────────────────────────────────────────────
SAVANT_CODE_POSTHOG_API_KEY=
SAVANT_CODE_POSTHOG_HOST=

# ───────────────────────────────────────────────────────────────────────────────
# SAVANT_CODE_* INTERNAL CONFIG (OPTIONAL — sensible defaults exist)
# ───────────────────────────────────────────────────────────────────────────────

# GitHub token (used for git operations from the agent — 10x usage in code)
SAVANT_CODE_GITHUB_TOKEN=

# npm registry override (defaults to https://registry.npmjs.org)
# SAVANT_CODE_NPM_REGISTRY=https://registry.npmjs.org

# Path to ripgrep binary (auto-detected if unset; set if rg isn't on PATH)
# SAVANT_CODE_RG_PATH=/usr/local/bin/rg

# Path to git bash on Windows (auto-detected if unset)
# SAVANT_CODE_GIT_BASH_PATH=C:\Program Files\Git\bin\bash.exe

# Path to tree-sitter WASM files (auto-detected if unset)
# SAVANT_CODE_WASM_DIR=
# SAVANT_CODE_TREE_SITTER_WASM_PATH=

# Editor to open for `editor`-style commands (defaults to $EDITOR or vim)
SAVANT_CODE_EDITOR=
SAVANT_CODE_CLI_EDITOR=

# CLI version override (set automatically by the release pipeline)
# SAVANT_CODE_CLI_VERSION=0.2.0

# CLI target (auto-detected: binary vs dev vs npm)
# SAVANT_CODE_CLI_TARGET=dev

# Running from a prebuilt binary (set by the release pipeline; do not set manually)
# SAVANT_CODE_IS_BINARY=1

# savant-free mode toggle (set by the savant-free release build)
# SAVANT_FREE_MODE=true

# Path to a savant-free binary (only used by the e2e tests)
# SAVANT_FREE_BINARY=

# Full-telemetry mode (verbose PostHog event names + user IDs)
# SAVANT_CODE_FULL_TELEMETRY=1
# SAVANT_CODE_FULL_TELEMETRY_IDS=1
# SAVANT_CODE_FULL_TELEMETRY_USER_IDS=user-123,user-456

# TUI tuning
# SAVANT_CODE_SCROLL_MULTIPLIER=3

# Debug / trace (verbose logging; set SAVANT_CODE_TRACE=1 for SDK traces)
# SAVANT_CODE_DEBUG=1
# SAVANT_CODE_TRACE=1

# Performance test mode (skips some UI)
# SAVANT_CODE_PERF_TEST=1

# Ship logs to the Savant-Code backend (off by default)
# SAVANT_CODE_SHIP_LOGS=1

# Running inside GitHub Actions
# SAVANT_CODE_GITHUB_ACTIONS=1

# ───────────────────────────────────────────────────────────────────────────────
# TEST / CI FLAGS (typically unset outside CI)
# ───────────────────────────────────────────────────────────────────────────────
# CI=                                 # Set by most CI providers automatically
# IS_PULL_REQUEST=                     # Set by GitHub Actions
# RUN_SAVANT_CODE_E2E=                 # Run savant-code e2e tests
# RUN_BASE_DEEP_SLOW_E2E=              # Run slow base-deep e2e tests
